---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = "Dashboard Admin Anak MPK SMAN 1 Malingping" } = Astro.props;
---

<!DOCTYPE html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    
    <link rel="icon" type="image/png" href="/images/Logo_MPK.jpeg" />
    <link rel="shortcut icon" href="/images/Logo_MPK.jpeg" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;700&family=Poppins:wght@300;400;600;700;900&display=swap" rel="stylesheet" />

    <!-- Phosphor Icons Web Font -->
    <script src="https://unpkg.com/@phosphor-icons/web@2.1.1"></script>

    <!-- Server-Side Protected by Astro Middleware -->
  </head>
  <body class="bg-cream-100 text-slate-800 font-['Poppins',sans-serif] min-h-screen flex flex-col md:flex-row antialiased">
    
    <!-- Sidebar Navigation (Dark Oak wood panel frame) -->
    <aside class="w-full md:w-64 sidebar-wood-panel flex flex-col md:justify-between p-6 shrink-0 z-20 md:h-screen md:sticky md:top-0">
      
      <!-- Brand Header Bar (Mobile row, Desktop stack) -->
      <div class="flex items-center justify-between w-full md:block">
        <div class="flex items-center space-x-3">
          <img src="/images/Logo_MPK.jpeg" alt="Logo" class="w-9 h-9 rounded-full border border-cream-500/30 object-cover" />
          <div>
            <div class="text-sm font-black tracking-wide text-white">MPK ADMIN</div>
            <div class="text-[10px] text-cream-300/50 font-bold tracking-wider uppercase font-mono">SMAN 1 Malingping</div>
          </div>
        </div>

        <!-- Mobile Menu Toggle Button -->
        <button 
          id="admin-mobile-btn" 
          class="md:hidden p-2 text-cream-200 hover:text-white focus:outline-none flex flex-col justify-center items-center gap-1.5 w-10 h-10 relative cursor-pointer" 
          aria-label="Toggle admin menu"
        >
          <span class="w-6 h-0.5 bg-cream-200 transition-all duration-300 transform origin-center"></span>
          <span class="w-6 h-0.5 bg-cream-200 transition-all duration-300 transform origin-center"></span>
          <span class="w-6 h-0.5 bg-cream-200 transition-all duration-300 transform origin-center font-medium"></span>
        </button>
      </div>

      <!-- Collapsible Navigation Drawer (Hidden on mobile by default) -->
      <div 
        id="admin-sidebar-menu" 
        class="hidden md:flex flex-col flex-1 justify-between mt-6 md:mt-8 space-y-8 md:space-y-0 w-full transition-all duration-300"
      >
        {/* Navigation Items */}
        <nav class="space-y-2.5 text-xs sm:text-sm font-semibold flex flex-col">
          <a 
            href="/admin" 
            class="flex items-center space-x-3.5 px-4 py-3 rounded-xl hover:bg-[#463629] text-cream-200/80 hover:text-white transition-all group"
            id="nav-overview"
          >
            <i class="ph-duotone ph-circles-four text-cream-300/30 group-hover:text-cream-500 text-lg transition"></i>
            <span>Ringkasan</span>
          </a>
          <a 
            href="/admin/members" 
            class="flex items-center space-x-3.5 px-4 py-3 rounded-xl hover:bg-[#463629] text-cream-200/80 hover:text-white transition-all group"
            id="nav-members"
          >
            <i class="ph-duotone ph-users-three text-cream-300/30 group-hover:text-cream-500 text-lg transition"></i>
            <span>CMS Anggota</span>
          </a>
          <a 
            href="/admin/alumni" 
            class="flex items-center space-x-3.5 px-4 py-3 rounded-xl hover:bg-[#463629] text-cream-200/80 hover:text-white transition-all group"
            id="nav-alumni"
          >
            <i class="ph-duotone ph-graduation-cap text-cream-300/30 group-hover:text-cream-500 text-lg transition"></i>
            <span>CMS Alumni Purna</span>
          </a>
          <a 
            href="/admin/positions" 
            class="flex items-center space-x-3.5 px-4 py-3 rounded-xl hover:bg-[#463629] text-cream-200/80 hover:text-white transition-all group"
            id="nav-positions"
          >
            <i class="ph-duotone ph-git-fork text-cream-300/30 group-hover:text-cream-500 text-lg transition"></i>
            <span>Hirarki Jabatan</span>
          </a>
          <a 
            href="/admin/classes" 
            class="flex items-center space-x-3.5 px-4 py-3 rounded-xl hover:bg-[#463629] text-cream-200/80 hover:text-white transition-all group"
            id="nav-classes"
          >
            <i class="ph-duotone ph-squares-four text-cream-300/30 group-hover:text-cream-500 text-lg transition"></i>
            <span>Kelola Kelas</span>
          </a>
          <a 
            href="/admin/aspirations" 
            class="flex items-center space-x-3.5 px-4 py-3 rounded-xl hover:bg-[#463629] text-cream-200/80 hover:text-white transition-all group"
            id="nav-aspirations"
          >
            <i class="ph-duotone ph-chat-centered-text text-cream-300/30 group-hover:text-cream-500 text-lg transition"></i>
            <span>Kelola Aspirasi</span>
          </a>
        </nav>

        {/* Footer / Account Management */}
        <div class="pt-6 border-t border-[#463629] mt-8 md:mt-0 space-y-4">
          
          <!-- Cozy ID Tag: Menampilkan profil admin yang login -->
          <div id="admin-profile-tag" class="hidden p-3 bg-[#4A3B2F]/60 border border-cream-500/10 rounded-xl flex items-center space-x-3 shadow-inner">
            <div class="w-8 h-8 rounded-full bg-cream-500 text-slate-950 flex items-center justify-center font-mono font-bold text-xs uppercase shadow border border-cream-300" id="admin-avatar-initial">
              ?
            </div>
            <div class="min-w-0 flex-1">
              <div class="text-[9px] text-cream-300/40 uppercase tracking-widest font-bold font-mono">Petugas Aktif</div>
              <div class="text-xs text-white font-semibold truncate font-mono" id="admin-email-text">Memuat...</div>
            </div>
          </div>

          <a 
            href="/" 
            class="flex items-center space-x-3 px-4 py-2 text-xs font-semibold text-cream-300/50 hover:text-cream-200 transition"
          >
            <i class="ph-duotone ph-arrow-left text-sm"></i>
            <span>Kembali ke Web Publik</span>
          </a>
          <button 
            id="logout-btn" 
            class="w-full flex items-center justify-center space-x-2 bg-red-950/20 hover:bg-red-900/40 border border-red-900/40 hover:border-red-900/85 text-red-300 hover:text-white font-bold py-2.5 rounded-xl text-xs transition cursor-pointer"
          >
            <i class="ph-duotone ph-sign-out text-sm"></i>
            <span>Keluar Sesi</span>
          </button>
        </div>
      </div>
    </aside>

    <!-- Main Workspace Content (Breathing Room) -->
    <main class="flex-1 p-8 md:p-12 overflow-y-auto z-0">
      <slot />
    </main>

    <!-- Cozy Reusable Custom Dialog Modal (Backdrop overlay) -->
    <div id="cozy-dialog-overlay" class="fixed inset-0 bg-[#34281E]/40 backdrop-blur-sm z-50 flex items-center justify-center hidden transition-opacity duration-300 opacity-0">
      <div class="cozy-paper-card max-w-sm w-full mx-4 p-6 shadow-2xl border-2 border-cream-400 bg-white scale-95 transition-transform duration-300 relative space-y-4">
        {/* Header */}
        <div class="flex items-center gap-2 text-amber-800">
          <i class="ph-duotone ph-scroll text-amber-800 text-xl shrink-0"></i>
          <h4 id="cozy-dialog-title" class="text-sm font-black uppercase tracking-wider font-mono">Konfirmasi</h4>
        </div>
        
        {/* Message */}
        <p id="cozy-dialog-message" class="text-xs text-slate-600 leading-relaxed font-medium">Apakah Anda yakin?</p>
        
        {/* Input (only for prompt mode) */}
        <div id="cozy-dialog-input-wrapper" class="hidden">
          <input 
            type="text" 
            id="cozy-dialog-input" 
            class="w-full bg-white border border-cream-300 rounded-xl px-3.5 py-2 text-slate-800 text-xs focus:outline-none focus:border-cream-500 focus:ring-2 focus:ring-cream-500/10 transition duration-200 font-medium"
            placeholder="Ketik sesuatu..."
          />
        </div>
        
        {/* Action Buttons */}
        <div class="flex items-center justify-end gap-3 pt-2">
          <button 
            type="button" 
            id="cozy-dialog-cancel" 
            class="px-4 py-2 bg-cream-100 hover:bg-cream-200 border border-cream-300 text-slate-700 font-bold text-[10px] uppercase tracking-wider rounded-xl transition cursor-pointer"
          >
            Batal
          </button>
          <button 
            type="button" 
            id="cozy-dialog-confirm" 
            class="px-4 py-2 bg-slate-900 hover:bg-slate-800 text-white font-bold text-[10px] uppercase tracking-wider rounded-xl shadow transition cursor-pointer"
          >
            Lanjutkan
          </button>
        </div>
      </div>
    </div>

    <script>
      import { supabase } from '../lib/supabase';

      // Admin mobile hamburger menu logic
      const mobileBtn = document.getElementById('admin-mobile-btn');
      const sidebarMenu = document.getElementById('admin-sidebar-menu');
      
      if (mobileBtn && sidebarMenu) {
        const spans = mobileBtn.querySelectorAll('span');
        mobileBtn.addEventListener('click', () => {
          const isClosed = sidebarMenu.classList.contains('hidden');
          if (isClosed) {
            // Open
            sidebarMenu.classList.remove('hidden');
            spans[0]?.classList.add('rotate-45', 'translate-y-2');
            spans[1]?.classList.add('opacity-0');
            spans[2]?.classList.add('-rotate-45', '-translate-y-2');
          } else {
            // Close
            sidebarMenu.classList.add('hidden');
            spans[0]?.classList.remove('rotate-45', 'translate-y-2');
            spans[1]?.classList.remove('opacity-0');
            spans[2]?.classList.remove('-rotate-45', '-translate-y-2');
          }
        });
      }

      // Set active state styling based on pathname
      const currentPath = window.location.pathname;
      const navOverview = document.getElementById('nav-overview');
      const navMembers = document.getElementById('nav-members');
      const navAlumni = document.getElementById('nav-alumni');
      const navPositions = document.getElementById('nav-positions');
      const navAspirations = document.getElementById('nav-aspirations');
      const navClasses = document.getElementById('nav-classes');

      // Clear standard styling
      const links = [navOverview, navMembers, navAlumni, navPositions, navAspirations, navClasses];
      links.forEach(link => {
        link?.classList.remove('bg-[#4A3B2F]', 'text-cream-500', 'border-r-4', 'border-cream-500', 'text-white');
        link?.classList.add('text-cream-200/80');
      });

      if (currentPath === '/admin') {
        navOverview?.classList.add('bg-[#4A3B2F]', 'text-cream-500', 'border-r-4', 'border-cream-500');
        navOverview?.classList.remove('text-cream-200/80');
      } else if (currentPath.includes('/admin/members')) {
        navMembers?.classList.add('bg-[#4A3B2F]', 'text-cream-500', 'border-r-4', 'border-cream-500');
        navMembers?.classList.remove('text-cream-200/80');
      } else if (currentPath.includes('/admin/alumni')) {
        navAlumni?.classList.add('bg-[#4A3B2F]', 'text-cream-500', 'border-r-4', 'border-cream-500');
        navAlumni?.classList.remove('text-cream-200/80');
      } else if (currentPath.includes('/admin/positions')) {
        navPositions?.classList.add('bg-[#4A3B2F]', 'text-cream-500', 'border-r-4', 'border-cream-500');
        navPositions?.classList.remove('text-cream-200/80');
      } else if (currentPath.includes('/admin/aspirations')) {
        navAspirations?.classList.add('bg-[#4A3B2F]', 'text-cream-500', 'border-r-4', 'border-cream-500');
        navAspirations?.classList.remove('text-cream-200/80');
      } else if (currentPath.includes('/admin/classes')) {
        navClasses?.classList.add('bg-[#4A3B2F]', 'text-cream-500', 'border-r-4', 'border-cream-500');
        navClasses?.classList.remove('text-cream-200/80');
      }

      // Cozy Reusable Dialog Logic
      const overlay = document.getElementById('cozy-dialog-overlay');
      const titleEl = document.getElementById('cozy-dialog-title');
      const msgEl = document.getElementById('cozy-dialog-message');
      const inputWrapper = document.getElementById('cozy-dialog-input-wrapper');
      const inputEl = document.getElementById('cozy-dialog-input') as HTMLInputElement | null;
      const cancelBtn = document.getElementById('cozy-dialog-cancel');
      const confirmBtn = document.getElementById('cozy-dialog-confirm');

      let onDialogConfirm: ((val?: string) => void) | null = null;
      let onDialogCancel: (() => void) | null = null;

      function closeCozyDialog() {
        if (!overlay) return;
        overlay.classList.add('opacity-0');
        overlay.querySelector('.cozy-paper-card')?.classList.add('scale-95');
        setTimeout(() => {
          overlay.classList.add('hidden');
        }, 300);
      }

      function openCozyDialog(title: string, message: string, isPrompt: boolean, defaultValue = '', placeholder = '') {
        if (!overlay || !titleEl || !msgEl || !inputWrapper || !inputEl) return;
        
        titleEl.textContent = title;
        msgEl.textContent = message;
        
        if (isPrompt) {
          inputWrapper.classList.remove('hidden');
          inputEl.value = defaultValue;
          inputEl.placeholder = placeholder;
          setTimeout(() => inputEl.focus(), 150);
        } else {
          inputWrapper.classList.add('hidden');
        }

        overlay.classList.remove('hidden');
        // trigger reflow
        overlay.offsetHeight;
        overlay.classList.remove('opacity-0');
        overlay.querySelector('.cozy-paper-card')?.classList.remove('scale-95');
      }

      // Expose to window for all pages nested in AdminLayout
      (window as any).showCozyConfirm = function(title: string, message: string, callback: () => void) {
        openCozyDialog(title, message, false);
        onDialogConfirm = () => {
          closeCozyDialog();
          callback();
        };
        onDialogCancel = () => {
          closeCozyDialog();
        };
      };

      (window as any).showCozyPrompt = function(title: string, message: string, defaultValue: string, placeholder: string, callback: (val: string) => void) {
        openCozyDialog(title, message, true, defaultValue, placeholder);
        onDialogConfirm = () => {
          const val = inputEl ? inputEl.value.trim() : '';
          closeCozyDialog();
          callback(val);
        };
        onDialogCancel = () => {
          closeCozyDialog();
        };
      };

      cancelBtn?.addEventListener('click', () => {
        if (onDialogCancel) onDialogCancel();
      });

      confirmBtn?.addEventListener('click', () => {
        if (onDialogConfirm) {
          if (inputWrapper && !inputWrapper.classList.contains('hidden') && inputEl) {
            onDialogConfirm(inputEl.value);
          } else {
            onDialogConfirm();
          }
        }
      });

      inputEl?.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') {
          confirmBtn?.click();
        }
      });

      // Logout handler
      document.getElementById('logout-btn')?.addEventListener('click', () => {
        (window as any).showCozyConfirm('Keluar Sesi', 'Apakah Anda yakin ingin keluar dari sesi admin?', async () => {
          await supabase.auth.signOut();
          // Delete cookies on logout safely across HTTP (local dev) and HTTPS
          const secureFlag = window.location.protocol === 'https:' ? '; Secure' : '';
          document.cookie = `sb-access-token=; path=/; expires=Thu, 01 Jan 1970 00:00:00 UTC; SameSite=Lax${secureFlag}`;
          document.cookie = `sb-refresh-token=; path=/; expires=Thu, 01 Jan 1970 00:00:00 UTC; SameSite=Lax${secureFlag}`;
          window.location.href = '/login?message=Berhasil keluar sesi';
        });
      });

      // Fetch active admin details dynamically
      (async function loadAdminProfile() {
        const profileTag = document.getElementById('admin-profile-tag');
        const emailText = document.getElementById('admin-email-text');
        const avatarInitial = document.getElementById('admin-avatar-initial');
        if (!profileTag || !emailText || !avatarInitial) return;

        try {
          const { data: { user } } = await supabase.auth.getUser();
          if (user && user.email) {
            emailText.textContent = user.email;
            avatarInitial.textContent = user.email.charAt(0).toUpperCase();
            profileTag.classList.remove('hidden');
          }
        } catch (err) {
          console.error("Gagal memuat profil admin:", err);
        }
      })();
    </script>
  </body>
</html>
