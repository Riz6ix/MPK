---
import AdminLayout from '../../layouts/AdminLayout.astro';

// Hybrid mode - SSR at edge
export const prerender = false;
---

<AdminLayout title="Kelola Aspirasi Siswa - Panel Admin">
  <div class="space-y-8">
    
    {/* Page Header */}
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
      <div>
        <h2 class="text-2xl sm:text-3xl font-black text-slate-900 uppercase tracking-wider">Kotak Aspirasi Masuk</h2>
        <p class="text-xs text-slate-600 font-medium mt-1">Pantau, ubah status penanganan, atau hapus aspirasi yang masuk dari murid.</p>
      </div>
      
      {/* Filter tab buttons */}
      <div class="flex flex-wrap items-center gap-1 bg-cream-200/80 border border-cream-300 p-1 rounded-xl w-fit text-xs font-bold text-slate-600 shadow-sm">
        <button class="px-3 py-1.5 rounded-lg bg-cream-500 text-slate-950 font-bold transition active-filter cursor-pointer" data-filter="all">Semua</button>
        <button class="px-3 py-1.5 rounded-lg hover:text-slate-800 transition cursor-pointer" data-filter="Belum Diproses">Belum Diproses</button>
        <button class="px-3 py-1.5 rounded-lg hover:text-slate-800 transition cursor-pointer" data-filter="Sedang Ditinjau">Sedang Ditinjau</button>
        <button class="px-3 py-1.5 rounded-lg hover:text-slate-800 transition cursor-pointer" data-filter="Selesai">Selesai</button>
        <button class="px-3 py-1.5 rounded-lg hover:text-slate-800 transition cursor-pointer" data-filter="Anomali">Anomali</button>
        <button class="px-3 py-1.5 rounded-lg hover:text-slate-800 transition cursor-pointer" data-filter="Pending">Pending</button>
        <button class="px-3 py-1.5 rounded-lg hover:text-slate-800 transition cursor-pointer" data-filter="Birokrasi">Birokrasi</button>
      </div>
    </div>

    {/* Alerts box */}
    <div id="status-toast" class="hidden p-3.5 rounded-xl border text-xs font-medium max-w-sm shadow-md transition duration-300"></div>

    {/* Aspirations Board / List */}
    <div class="cozy-paper-card p-6 shadow-md relative min-h-[300px]">
      
      <!-- Search Input Wrapper -->
      <div id="search-wrapper" class="hidden mb-6 max-w-sm">
        <div class="relative">
          <span class="absolute left-3.5 top-[13px] text-slate-500 text-xs"><i class="ph-bold ph-magnifying-glass"></i></span>
          <input 
            type="text" 
            id="search-input" 
            placeholder="Cari kelas, pengirim, atau isi keluhan..." 
            class="w-full bg-white border border-cream-300 rounded-xl pl-11 pr-4 py-3 text-slate-800 text-xs sm:text-sm focus:outline-none focus:border-cream-500 focus:ring-2 focus:ring-cream-500/10 transition duration-200 leading-normal"
          />
        </div>
      </div>

      {/* Loading State Indicator */}
      <div id="table-loading" class="flex flex-col items-center justify-center py-16 space-y-3">
        <svg class="animate-spin h-8 w-8 text-cream-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
        </svg>
        <p class="text-slate-500 text-xs font-semibold">Memuat aspirasi...</p>
      </div>

      {/* Empty State */}
      <div id="table-empty" class="hidden text-center py-16">
        <p class="text-slate-600 text-sm font-medium">Tidak ditemukan aspirasi dalam kategori ini.</p>
      </div>

      {/* Interactive Table & Mobile Cards Container */}
      <div id="table-wrapper" class="hidden">
        
        {/* Desktop View */}
        <div id="desktop-table-wrapper" class="hidden sm:block overflow-x-auto">
          <table class="w-full text-left text-sm text-slate-600">
            <thead>
              <tr class="border-b border-cream-200 text-slate-500 font-bold text-xs uppercase tracking-wider">
                <th class="py-3 px-2">Tanggal</th>
                <th class="py-3 px-2">Siswa</th>
                <th class="py-3 px-2">Isi Aspirasi</th>
                <th class="py-3 px-2">Hulu IP</th>
                <th class="py-3 px-2">Status Penanganan</th>
                <th class="py-3 px-2 text-right">Aksi</th>
              </tr>
            </thead>
            <tbody id="aspirations-tbody" class="divide-y divide-cream-100">
              {/* Populated dynamically via client-side script */}
            </tbody>
          </table>
        </div>

        {/* Mobile View */}
        <div id="mobile-cards-wrapper" class="block sm:hidden space-y-4">
          {/* Populated dynamically via client-side script */}
        </div>

      </div>

      <!-- Pagination Controls Wrapper -->
      <div id="pagination-wrapper" class="hidden flex flex-col sm:flex-row items-center justify-between gap-4 mt-6 pt-4 border-t border-cream-200 text-xs font-bold text-slate-600">
        <div id="pagination-info">
          Menampilkan <span id="paginated-start" class="text-slate-900 font-mono">1</span> - <span id="paginated-end" class="text-slate-900 font-mono">10</span> dari <span id="paginated-total" class="text-slate-900 font-mono">100</span> aspirasi
        </div>
        <div class="flex items-center space-x-2">
          <button 
            id="pagination-prev" 
            class="px-4 py-2 rounded-xl bg-cream-100 border border-cream-300 text-slate-700 hover:bg-cream-200 disabled:opacity-40 disabled:cursor-not-allowed transition cursor-pointer"
          >
            Sebelumnya
          </button>
          <button 
            id="pagination-next" 
            class="px-4 py-2 rounded-xl bg-cream-100 border border-cream-300 text-slate-700 hover:bg-cream-200 disabled:opacity-40 disabled:cursor-not-allowed transition cursor-pointer"
          >
            Berikutnya
          </button>
        </div>
      </div>

    </div>

  </div>
</AdminLayout>

<script>
  import { supabase, logActivity } from '../../lib/supabase';

  let aspirations: any[] = [];
  let currentFilter = 'all';
  let searchQuery = '';
  let currentPage = 1;
  const ITEMS_PER_PAGE = 10;

  function escapeHtmlAttr(str: string) {
    if (!str) return '';
    return str
      .replace(/\\/g, '\\\\')
      .replace(/`/g, '\\`')
      .replace(/\$/g, '\\$')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  const loadingEl = document.getElementById('table-loading');
  const emptyEl = document.getElementById('table-empty');
  const wrapperEl = document.getElementById('table-wrapper');
  const tbodyEl = document.getElementById('aspirations-tbody');
  const mobileCardsEl = document.getElementById('mobile-cards-wrapper');
  const toastEl = document.getElementById('status-toast');

  // Load initially
  fetchAspirations();

  // Set up Supabase Real-Time Channel subscription for aspirations table
  const channel = supabase
    .channel('aspirations-realtime-sync')
    .on(
      'postgres_changes',
      { event: '*', schema: 'public', table: 'aspirations' },
      () => {
        // Refetch silently from DB on change
        fetchAspirations(true);
      }
    )
    .subscribe();

  async function fetchAspirations(isSilent = false) {
    if (!isSilent) showLoading(true);
    try {
      const { data, error } = await supabase
        .from('aspirations')
        .select('*')
        .order('created_at', { ascending: false });

      if (error) throw error;
      aspirations = data || [];
      renderTable();
    } catch (err: any) {
      showToast('error', 'Gagal memuat aspirasi: ' + err.message);
    }
  }

  function showLoading(isLoading: boolean) {
    if (isLoading) {
      loadingEl?.classList.remove('hidden');
      emptyEl?.classList.add('hidden');
      wrapperEl?.classList.add('hidden');
    } else {
      loadingEl?.classList.add('hidden');
    }
  }

  function showToast(type: 'success' | 'error', msg: string) {
    if (!toastEl) return;
    toastEl.classList.remove('hidden', 'bg-emerald-50', 'border-emerald-200', 'text-emerald-700', 'bg-red-50', 'border-red-200', 'text-red-700');
    
    if (type === 'success') {
      toastEl.classList.add('bg-emerald-50', 'border-emerald-200', 'text-emerald-700');
    } else {
      toastEl.classList.add('bg-red-50', 'border-red-200', 'text-red-700');
    }
    toastEl.textContent = msg;
    toastEl.classList.remove('hidden');

    setTimeout(() => {
      toastEl.classList.add('hidden');
    }, 4000);
  }

  function renderTable() {
    showLoading(false);
    
    // 1. Filter data by Category AND Search Query
    let filtered = aspirations;
    
    if (currentFilter !== 'all') {
      filtered = filtered.filter(asp => asp.status === currentFilter);
    }
    
    if (searchQuery.trim() !== '') {
      const q = searchQuery.toLowerCase().trim();
      filtered = filtered.filter(asp => 
        (asp.name && asp.name.toLowerCase().includes(q)) ||
        (asp.class && asp.class.toLowerCase().includes(q)) ||
        (asp.content && asp.content.toLowerCase().includes(q))
      );
    }

    const totalItems = filtered.length;

    // Toggle element wrappers
    const searchWrapper = document.getElementById('search-wrapper');
    const paginationWrapper = document.getElementById('pagination-wrapper');

    if (totalItems === 0) {
      emptyEl?.classList.remove('hidden');
      wrapperEl?.classList.add('hidden');
      if (searchWrapper) {
        if (searchQuery.trim() !== '') searchWrapper.classList.remove('hidden');
        else searchWrapper.classList.add('hidden');
      }
      if (paginationWrapper) paginationWrapper.classList.add('hidden');
      return;
    }

    emptyEl?.classList.add('hidden');
    wrapperEl?.classList.remove('hidden');
    if (searchWrapper) searchWrapper.classList.remove('hidden');
    if (paginationWrapper) paginationWrapper.classList.remove('hidden');

    // 2. Slicing pagination
    const totalPages = Math.ceil(totalItems / ITEMS_PER_PAGE) || 1;
    if (currentPage > totalPages) currentPage = totalPages;
    if (currentPage < 1) currentPage = 1;

    const startIndex = (currentPage - 1) * ITEMS_PER_PAGE;
    const endIndex = Math.min(startIndex + ITEMS_PER_PAGE, totalItems);
    const paginatedItems = filtered.slice(startIndex, endIndex);

    // Update pagination panel texts
    const startEl = document.getElementById('paginated-start');
    const endEl = document.getElementById('paginated-end');
    const totalEl = document.getElementById('paginated-total');
    
    if (startEl) startEl.textContent = (startIndex + 1).toString();
    if (endEl) endEl.textContent = endIndex.toString();
    if (totalEl) totalEl.textContent = totalItems.toString();
    
    // Enable/disable buttons
    const prevBtn = document.getElementById('pagination-prev') as HTMLButtonElement | null;
    const nextBtn = document.getElementById('pagination-next') as HTMLButtonElement | null;
    
    if (prevBtn) prevBtn.disabled = currentPage === 1;
    if (nextBtn) nextBtn.disabled = currentPage === totalPages;

    // Clear previous containers
    if (tbodyEl) tbodyEl.innerHTML = '';
    if (mobileCardsEl) mobileCardsEl.innerHTML = '';

    paginatedItems.forEach((asp) => {
      // Date Format
      const date = new Date(asp.created_at).toLocaleDateString('id-ID', {
        day: '2-digit',
        month: 'short',
        year: 'numeric',
        hour: '2-digit',
        minute: '2-digit'
      });

      const cleanName = asp.name || 'Anonim';
      
      // Text Truncation Logic
      const rawContent = asp.content || '';
      const hasNewlines = rawContent.includes('\n');
      const isLong = rawContent.length > 80 || hasNewlines;
      const truncated = isLong 
        ? (rawContent.replace(/\r?\n/g, ' ').substring(0, 80) + '...') 
        : rawContent;

      const escapedFull = escapeHtmlAttr(rawContent);
      const escapedTruncated = escapeHtmlAttr(truncated);

      // A. Populate Desktop Row
      if (tbodyEl) {
        const row = document.createElement('tr');
        row.className = 'hover:bg-cream-100/40 border-b border-cream-200/50 transition duration-150 text-xs sm:text-sm';
        row.innerHTML = `
          <td class="py-4 px-2 text-slate-500 font-mono font-bold text-xs">${date}</td>
          <td class="py-4 px-2">
            <div class="font-black text-slate-900">${cleanName}</div>
            <div class="text-[10px] text-slate-500 font-mono font-bold uppercase mt-0.5 tracking-wider">${asp.class}</div>
            ${asp.response ? `
              <span class="inline-flex items-center gap-1 text-[8.5px] font-mono font-bold text-emerald-700 bg-emerald-50 border border-emerald-200 px-1.5 py-0.5 rounded mt-1.5">
                <i class="ph-bold ph-check-circle"></i> Respon Aktif
              </span>
            ` : `
              <span class="inline-flex items-center gap-1 text-[8.5px] font-mono font-bold text-amber-700 bg-amber-50 border border-amber-200 px-1.5 py-0.5 rounded mt-1.5">
                <i class="ph-bold ph-chats-teardrop"></i> Belum Dibalas
              </span>
            `}
          </td>
          <td class="py-4 px-2 max-w-sm">
            <div class="content-wrapper">
              <p class="text-slate-800 leading-relaxed font-medium break-words content-text whitespace-pre-wrap" data-full="${escapedFull}" data-truncated="${escapedTruncated}">${truncated}</p>
              ${isLong ? `
                <button class="expand-content-btn text-[9px] font-bold text-cream-700 hover:text-cream-800 uppercase mt-1 cursor-pointer flex items-center gap-0.5">
                  Lihat Selengkapnya <i class="ph-bold ph-caret-down"></i>
                </button>
              ` : ''}
            </div>
            
            <!-- Tanggapan Admin Box -->
            <div class="mt-3 space-y-1 bg-[#FAF6F0] border border-cream-300/40 rounded-xl p-2.5">
              <div class="flex items-center justify-between mb-1">
                <label class="text-[9px] font-bold text-cream-700 uppercase tracking-wider block font-mono flex items-center gap-1">
                  <i class="ph-duotone ph-chat-centered-text text-amber-600"></i> Tanggapan Resmi MPK
                </label>
                ${asp.response ? `
                  <span class="inline-flex items-center gap-0.5 text-[8px] font-black font-mono text-emerald-700 bg-emerald-100/80 border border-emerald-300/40 px-1.5 py-0.5 rounded uppercase tracking-wider">
                    <i class="ph-bold ph-check text-[9px]"></i> Sudah Ditanggapi
                  </span>
                ` : `
                  <span class="inline-flex items-center gap-0.5 text-[8px] font-black font-mono text-amber-700 bg-amber-100/80 border border-amber-300/40 px-1.5 py-0.5 rounded uppercase tracking-wider">
                    <i class="ph-bold ph-warning text-[9px]"></i> Belum Ditanggapi
                  </span>
                `}
              </div>
              <div class="flex items-center gap-2">
                <textarea 
                  data-id="${asp.id}" 
                  class="response-textarea w-full bg-white border border-cream-300 rounded-xl px-3.5 py-2.5 text-xs text-slate-800 font-medium focus:outline-none focus:border-cream-500 focus:ring-1 focus:ring-cream-500/10 transition duration-150 resize-y leading-relaxed" 
                  rows="1" 
                  placeholder="Ketik respon resmi..."
                >${asp.response || ''}</textarea>
                <button 
                  data-id="${asp.id}" 
                  class="save-response-btn px-2.5 py-1.5 bg-slate-900 hover:bg-slate-850 text-white rounded-lg text-[10px] font-bold tracking-wider uppercase transition active:scale-95 cursor-pointer shrink-0"
                >
                  Simpan
                </button>
              </div>
            </div>
          </td>
          <td class="py-4 px-2">
            <code class="text-[10px] text-cream-600 bg-cream-100 border border-cream-300/40 px-2 py-1 rounded font-mono">${asp.ip_hash.substring(0, 8)}</code>
          </td>
          <td class="py-4 px-2">
            <select 
              data-id="${asp.id}" 
              class="status-select bg-white border border-cream-300 rounded-xl px-2.5 py-1.5 text-xs text-slate-800 font-mono font-bold focus:outline-none focus:border-cream-500 focus:ring-2 focus:ring-cream-500/10 cursor-pointer min-w-[145px] max-w-[170px]"
            >
              <option value="Belum Diproses" ${asp.status === 'Belum Diproses' ? 'selected' : ''}>Belum Diproses</option>
              <option value="Sedang Ditinjau" ${asp.status === 'Sedang Ditinjau' ? 'selected' : ''}>Sedang Ditinjau</option>
              <option value="Selesai" ${asp.status === 'Selesai' ? 'selected' : ''}>Selesai</option>
              <option value="Anomali" ${asp.status === 'Anomali' ? 'selected' : ''}>Anomali</option>
              <option value="Pending" ${asp.status === 'Pending' ? 'selected' : ''}>Pending</option>
              <option value="Birokrasi" ${asp.status === 'Birokrasi' ? 'selected' : ''}>Birokrasi</option>
            </select>
          </td>
          <td class="py-4 px-2 text-right">
            <button 
              data-id="${asp.id}" 
              class="delete-btn text-xs font-semibold text-red-600 hover:text-red-700 hover:underline cursor-pointer"
              aria-label="Hapus aspirasi dari ${cleanName}, kelas ${asp.class}"
            >
              Hapus
            </button>
          </td>
        `;
        tbodyEl.appendChild(row);
      }

      // B. Populate Mobile Card (Android/iOS HP Aligned)
      if (mobileCardsEl) {
        const card = document.createElement('div');
        card.className = 'bg-white border border-cream-300/80 rounded-2xl p-5 space-y-4 shadow-sm relative text-left';
        card.innerHTML = `
          <div class="flex justify-between items-start border-b border-cream-200/50 pb-3">
            <div>
              <div class="font-black text-sm text-slate-900">${cleanName}</div>
              <div class="flex items-center gap-2 mt-1">
                <span class="text-[9px] text-slate-500 font-mono font-bold uppercase tracking-wider">${asp.class}</span>
                ${asp.response ? `
                  <span class="text-[8px] font-mono font-bold text-emerald-700 bg-emerald-50 border border-emerald-200 px-1.5 py-0.5 rounded flex items-center gap-0.5">
                    <i class="ph-bold ph-check"></i> Respon Aktif
                  </span>
                ` : `
                  <span class="text-[8px] font-mono font-bold text-amber-700 bg-amber-50 border border-amber-200 px-1.5 py-0.5 rounded flex items-center gap-0.5">
                    <i class="ph-bold ph-chats-teardrop"></i> Belum Dibalas
                  </span>
                `}
              </div>
            </div>
            <span class="text-[9px] text-slate-400 font-mono font-bold bg-cream-100 border border-cream-200 px-2 py-0.5 rounded">${date.substring(0, 11)}</span>
          </div>
          
          <div class="space-y-1.5">
            <label class="text-[9px] font-bold text-slate-400 uppercase tracking-widest font-mono block">Isi Keluhan</label>
            <div class="content-wrapper">
              <p class="text-slate-800 text-sm font-medium leading-relaxed break-words content-text whitespace-pre-wrap" data-full="${escapedFull}" data-truncated="${escapedTruncated}">${truncated}</p>
              ${isLong ? `
                <button class="expand-content-btn text-[9px] font-bold text-cream-700 hover:text-cream-800 uppercase mt-1 cursor-pointer flex items-center gap-0.5">
                  Lihat Selengkapnya <i class="ph-bold ph-caret-down"></i>
                </button>
              ` : ''}
            </div>
          </div>
          
          <div class="grid grid-cols-2 gap-4 items-end text-xs">
            <div class="space-y-1">
              <label class="text-[9px] font-bold text-slate-400 uppercase tracking-widest font-mono block">Hulu IP</label>
              <code class="text-[10px] text-cream-750 bg-cream-100/80 border border-cream-300/60 px-3 py-2 rounded-xl font-mono block w-full text-center">${asp.ip_hash.substring(0, 8)}</code>
            </div>
            <div class="space-y-1">
              <label class="text-[9px] font-bold text-slate-400 uppercase tracking-widest font-mono block">Status Penanganan</label>
              <select 
                data-id="${asp.id}" 
                class="status-select bg-white border border-cream-300 rounded-xl px-3 py-1.5 text-xs text-slate-800 font-mono font-bold focus:outline-none focus:border-cream-500 w-full cursor-pointer text-center"
              >
                <option value="Belum Diproses" ${asp.status === 'Belum Diproses' ? 'selected' : ''}>Belum Diproses</option>
                <option value="Sedang Ditinjau" ${asp.status === 'Sedang Ditinjau' ? 'selected' : ''}>Sedang Ditinjau</option>
                <option value="Selesai" ${asp.status === 'Selesai' ? 'selected' : ''}>Selesai</option>
                <option value="Anomali" ${asp.status === 'Anomali' ? 'selected' : ''}>Anomali</option>
                <option value="Pending" ${asp.status === 'Pending' ? 'selected' : ''}>Pending</option>
                <option value="Birokrasi" ${asp.status === 'Birokrasi' ? 'selected' : ''}>Birokrasi</option>
              </select>
            </div>
          </div>
          
          <!-- Tanggapan Admin Box (Mobile) -->
          <div class="space-y-2.5 bg-[#FAF6F0] border border-cream-300/40 rounded-xl p-3.5">
            <div class="flex items-center justify-between">
              <label class="text-[9px] font-bold text-cream-700 uppercase tracking-wider block font-mono flex items-center gap-1">
                <i class="ph-duotone ph-chat-centered-text text-amber-600"></i> Tanggapan Resmi MPK
              </label>
              ${asp.response ? `
                <span class="inline-flex items-center gap-0.5 text-[8px] font-black font-mono text-emerald-700 bg-emerald-100/80 border border-emerald-300/40 px-1.5 py-0.5 rounded uppercase tracking-wider">
                  <i class="ph-bold ph-check text-[9px]"></i> Sudah Ditanggapi
                </span>
              ` : `
                <span class="inline-flex items-center gap-0.5 text-[8px] font-black font-mono text-amber-700 bg-amber-100/80 border border-amber-300/40 px-1.5 py-0.5 rounded uppercase tracking-wider">
                  <i class="ph-bold ph-warning text-[9px]"></i> Belum Ditanggapi
                </span>
              `}
            </div>
            <textarea 
              data-id="${asp.id}" 
              class="response-textarea w-full bg-white border border-cream-300 rounded-xl px-3.5 py-2.5 text-xs text-slate-800 font-medium focus:outline-none focus:border-cream-500 focus:ring-1 focus:ring-cream-500/10 transition duration-150 resize-y leading-relaxed" 
              rows="2" 
              placeholder="Ketik respon resmi..."
            >${asp.response || ''}</textarea>
            <button 
              data-id="${asp.id}" 
              class="save-response-btn w-full py-2 bg-slate-900 hover:bg-slate-850 text-white rounded-xl text-xs font-bold tracking-wider uppercase transition active:scale-95 cursor-pointer text-center block"
            >
              Simpan Tanggapan
            </button>
          </div>
          
          <div class="flex justify-between items-center pt-2 border-t border-cream-100">
            <span class="text-[9px] text-slate-400 font-mono">${date.substring(12)}</span>
            <button 
              data-id="${asp.id}" 
              class="delete-btn text-xs font-bold text-red-600 hover:text-red-700 flex items-center gap-1 cursor-pointer py-1.5"
              aria-label="Hapus aspirasi dari ${cleanName}"
            >
              <i class="ph-bold ph-trash"></i> Hapus Aspirasi
            </button>
          </div>
        `;
        mobileCardsEl.appendChild(card);
      }
    });

    if (!wrapperEl) return;

    // Add Expand Content Button Listeners across all layouts
    wrapperEl.querySelectorAll('.expand-content-btn').forEach((btn) => {
      btn.addEventListener('click', (e: any) => {
        const targetBtn = e.currentTarget;
        const container = targetBtn.closest('.content-wrapper');
        if (!container) return;
        const textEl = container.querySelector('.content-text');
        if (!textEl) return;
        
        const isExpanded = targetBtn.getAttribute('data-expanded') === 'true';
        
        if (isExpanded) {
          textEl.textContent = textEl.getAttribute('data-truncated');
          targetBtn.innerHTML = 'Lihat Selengkapnya <i class="ph-bold ph-caret-down"></i>';
          targetBtn.setAttribute('data-expanded', 'false');
        } else {
          textEl.textContent = textEl.getAttribute('data-full');
          targetBtn.innerHTML = 'Sembunyikan <i class="ph-bold ph-caret-up"></i>';
          targetBtn.setAttribute('data-expanded', 'true');
        }
      });
    });

    // Add Select Change Listeners across all layouts
    wrapperEl.querySelectorAll('.status-select').forEach((select) => {
      select.addEventListener('change', async (e: any) => {
        const id = e.target.getAttribute('data-id');
        const status = e.target.value;
        try {
          const { error } = await supabase
            .from('aspirations')
            .update({ status })
            .eq('id', id);

          if (error) throw error;
          
          // Update local state array
          const index = aspirations.findIndex(asp => asp.id === id);
          if (index !== -1) aspirations[index].status = status;

          showToast('success', 'Status aspirasi berhasil diperbarui!');
          logActivity({
            action: 'UPDATE_ASPIRATION_STATUS',
            entity_type: 'aspiration',
            entity_id: id,
            detail: `Status diubah ke: ${status}`
          });
          
          // Sync dropdowns in both layouts by rerendering silently
          renderTable();
        } catch (err: any) {
          showToast('error', 'Gagal memperbarui status: ' + err.message);
        }
      });
    });

    // Add Save Response Button Listeners across all layouts with dynamic indicator and styles
    wrapperEl.querySelectorAll('.save-response-btn').forEach((btn) => {
      btn.addEventListener('click', async (e: any) => {
        const targetBtn = e.currentTarget;
        const id = targetBtn.getAttribute('data-id');
        // Find relative textarea inside the same container block
        const parent = targetBtn.parentElement;
        const textarea = parent ? parent.querySelector('textarea') : null;
        if (!textarea) return;
        
        const responseText = textarea.value.trim();
        
        // Visual loading state on button
        const originalText = targetBtn.textContent;
        targetBtn.textContent = 'Menyimpan...';
        targetBtn.disabled = true;
        
        try {
          const { error } = await supabase
            .from('aspirations')
            .update({ response: responseText })
            .eq('id', id);

          if (error) throw error;
          
          // Update local state array
          const index = aspirations.findIndex(asp => asp.id === id);
          if (index !== -1) aspirations[index].response = responseText;

          showToast('success', 'Aman, respon udah dikirim.');
          logActivity({
            action: 'RESPOND_ASPIRATION',
            entity_type: 'aspiration',
            entity_id: id,
            detail: `Tanggapan dikirim: "${responseText.substring(0, 80)}${responseText.length > 80 ? '...' : ''}"`
          });
          
          // Change button style to green "Tersimpan" temporarily
          targetBtn.textContent = '✓ Tersimpan';
          targetBtn.classList.remove('bg-slate-900', 'hover:bg-slate-855', 'bg-slate-900', 'hover:bg-slate-850');
          targetBtn.classList.add('bg-emerald-600', 'hover:bg-emerald-600', 'text-white');
          
          setTimeout(() => {
            // Rerender silently after 1.5s to restore buttons and update "Respon Aktif" badge
            renderTable();
          }, 1500);
          
        } catch (err: any) {
          showToast('error', 'Gagal menyimpan tanggapan: ' + err.message);
          targetBtn.textContent = originalText;
          targetBtn.disabled = false;
        }
      });
    });

    // Add Delete Button Listeners across all layouts
    wrapperEl.querySelectorAll('.delete-btn').forEach((btn) => {
      btn.addEventListener('click', (e: any) => {
        const id = e.currentTarget.getAttribute('data-id');
        (window as any).showCozyConfirm(
          'Hapus Aspirasi',
          'Hapus aspirasi ini? Ga bisa balik lagi ya.',
          async () => {
            try {
              const aspToDelete = aspirations.find(asp => asp.id === id);
              const cleanDetail = aspToDelete ? `Aspirasi dari ${aspToDelete.name} (${aspToDelete.class})` : 'Aspirasi';
              
              const { error } = await supabase
                .from('aspirations')
                .delete()
                .eq('id', id);

              if (error) throw error;

              logActivity({
                action: 'DELETE_ASPIRATION',
                entity_type: 'aspiration',
                entity_id: id,
                detail: cleanDetail
              });

              // Remove from local state
              aspirations = aspirations.filter(asp => asp.id !== id);
              showToast('success', 'Aman, aspirasi dihapus.');
              renderTable();
            } catch (err: any) {
              showToast('error', 'Gagal menghapus aspirasi: ' + err.message);
            }
          }
        );
      });
    });
  }

  // Search input handler
  const searchInput = document.getElementById('search-input') as HTMLInputElement | null;
  searchInput?.addEventListener('input', (e: any) => {
    searchQuery = e.target.value;
    currentPage = 1; // Reset to page 1 on search
    renderTable();
  });

  // Prev / Next button click handlers
  document.getElementById('pagination-prev')?.addEventListener('click', () => {
    if (currentPage > 1) {
      currentPage--;
      renderTable();
    }
  });

  document.getElementById('pagination-next')?.addEventListener('click', () => {
    currentPage++;
    renderTable();
  });

  // Filter click handlers
  document.querySelectorAll('[data-filter]').forEach(button => {
    button.addEventListener('click', (e: any) => {
      // Remove active class
      document.querySelectorAll('[data-filter]').forEach(btn => {
        btn.classList.remove('bg-cream-500', 'text-slate-950', 'font-bold');
        btn.classList.add('hover:text-slate-800');
      });

      // Add active class
      e.target.classList.add('bg-cream-500', 'text-slate-950', 'font-bold');
      e.target.classList.remove('hover:text-slate-800');

      currentFilter = e.target.getAttribute('data-filter');
      currentPage = 1; // Reset page on category filter change
      renderTable();
    });
  });
</script>
