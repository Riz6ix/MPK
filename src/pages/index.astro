                            {/* Pink / Blue Gender Dot badge */}
                            <span class={`absolute bottom-0 right-0 w-2.5 h-2.5 rounded-full border border-white shadow-sm z-10 ${
                              m.gender === 'Perempuan' ? 'bg-pink-400' : 'bg-blue-400'
                            }`} title={m.gender || 'Laki-laki'}></span>
                          </div>
                          <div class="min-w-0">
                            <div class="text-xs font-bold text-charcoal-900 truncate">{m.name}</div>
                            <div class="text-[9px] text-slate-500 font-mono font-semibold">{m.position} · <span class="font-bold tracking-wider">{m.class}</span></div>
                          </div>
                        </div>
                      );
                    })}
                  </div>
                )}
              </div>
            );
          })}
        </div>
      </div>

      <!-- Cozy Alumni & Divider Wrapper -->
      {sortedGenerations.length > 0 && (
        <div class="space-y-6 reveal">
          <!-- Divider with graduation ornament -->
          <div class="flex items-center justify-center gap-4 pt-3">
            <div class="h-px flex-1 max-w-[120px] bg-gradient-to-r from-transparent to-cream-400/60"></div>
            <span class="text-cream-400 text-lg select-none">🎓</span>
            <div class="h-px flex-1 max-w-[120px] bg-gradient-to-l from-transparent to-cream-400/60"></div>
          </div>

          <!-- 3. Direktori Purna Bakti Accordion -->
          <details id="hall-of-prestige" class="group bg-gradient-to-r from-amber-50/20 via-white/80 to-cream-100/20 hover:from-amber-50/40 hover:to-white/95 backdrop-blur-sm border border-cream-300/60 open:border-amber-400/50 open:ring-4 open:ring-amber-400/10 rounded-2xl shadow-sm open:shadow-md transition-all duration-300 [&_summary::-webkit-details-marker]:hidden">
            <summary class="flex items-center justify-between p-6 cursor-pointer select-none hover:text-amber-600 transition-colors duration-300">
              <div class="flex items-center gap-3">
                <div class="flex flex-col sm:flex-row sm:items-center gap-1.5 sm:gap-3">
                  <div class="flex items-center gap-2.5">
                    <img src="/images/mc/dragon.png" class="w-6 h-6 pixelated shrink-0 group-hover:drop-shadow-[0_0_6px_rgba(245,158,11,0.6)] group-hover:scale-110 transition duration-300" alt="Dragon" />
                    <span class="text-xs sm:text-sm font-black text-charcoal-900 uppercase tracking-wide group-open:text-amber-600">
                      Hall of Prestige
                    </span>
                  </div>
                  <span class="hidden sm:inline text-slate-300 select-none">|</span>
                  <span class="text-[9px] sm:text-[10px] font-mono font-bold text-amber-700 bg-amber-100/50 border border-amber-300/30 px-2 py-0.5 rounded uppercase tracking-wider self-start sm:self-auto flex items-center gap-1">
                    ✨ Honored Legacy — Jajaran Purna Bakti
                  </span>
                </div>
              </div>
              <span class="transition-transform duration-300 group-open:rotate-180 text-amber-500 text-lg shrink-0">
                <i class="ph-bold ph-caret-down"></i>
              </span>
            </summary>
            
            <div class="px-6 pb-6 border-t border-cream-200/60 pt-6 space-y-8 animate-fade-up" style="animation-duration: 0.5s">
              {sortedGenerations.map((gen) => {
                const genMembers = demisionerByGen[gen];
                return (
                  <div class="space-y-4">
                    <div class="space-y-2 pb-2.5 border-b border-cream-200/40">
                      <div class="flex items-center gap-3 flex-wrap">
                        <h4 class="text-xs font-black uppercase tracking-wider text-amber-900 font-mono bg-gradient-to-r from-amber-100 to-cream-200 border border-amber-300/60 px-3 py-1 rounded-lg shadow-sm">
                          {gen}
                        </h4>
                        {genMembers[0]?.generations?.graduation_year && (
                          <span class="text-[9px] font-mono font-bold text-amber-800 bg-amber-100/40 border border-amber-300/30 px-2 py-0.5 rounded-full">
                            🎓 Lulus {genMembers[0].generations.graduation_year}
                          </span>
                        )}
                        {genMembers[0]?.generations?.active_year && (
                          <span class="text-[9px] font-mono font-semibold text-amber-600 bg-amber-50 border border-amber-200 px-2 py-0.5 rounded-full">
                            ⌛ Masa Khidmat {genMembers[0].generations.active_year}
                          </span>
                        )}
                        <div class="h-px flex-1 bg-cream-300/30"></div>
                        <span class="text-[10px] text-slate-400 font-mono font-bold">{genMembers.length} Honored Purna</span>
                      </div>
                      <span class="text-[9.5px] text-amber-700/70 italic font-mono block pl-1">
                        "A distinguished cohort that laid the foundations of leadership with honor and integrity."
                      </span>
                    </div>

                    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3">
                      {genMembers.map((m: any) => (
                        <div class="flex items-center gap-3 bg-gradient-to-br from-white/95 to-cream-50/50 border border-cream-200 hover:border-amber-400/50 hover:shadow-[0_6px_16px_rgba(245,158,11,0.08)] p-3 rounded-xl opacity-90 hover:opacity-100 hover:from-amber-50/40 hover:to-white/95 transition duration-300 group/alumni shadow-sm">
                          <div class="relative shrink-0">
                            <img 
                              src={m.avatar_url || "/images/Logo_MPK.jpeg"} 
                              alt={m.name} 
                              class="w-10 h-10 rounded-full object-cover border-2 border-cream-300 group-hover/alumni:border-amber-400 group-hover/alumni:scale-105 transition-all duration-300 filter grayscale-[15%] group-hover/alumni:grayscale-0"
                            />
                            {/* Pink / Blue Gender Dot badge */}
                            <span class={`absolute bottom-0 right-0 w-2.5 h-2.5 rounded-full border border-white shadow-sm z-10 ${
                              m.gender === 'Perempuan' ? 'bg-pink-400' : 'bg-blue-400'
                            }`} title={m.gender || 'Laki-laki'}></span>
                          </div>
                          <div class="min-w-0 flex-1">
                            <span class="text-[7px] font-mono font-black tracking-widest uppercase text-amber-600 bg-amber-100/40 border border-amber-300/20 px-1.5 py-0.5 rounded w-fit block mb-1">
                              Honored Legacy
                            </span>
                            <div class="text-xs font-bold text-charcoal-900 leading-tight line-clamp-2 group-hover/alumni:text-amber-800 transition-colors duration-200">{m.name}</div>
                            <div class="text-[10px] text-slate-500 font-mono font-semibold mt-0.5 line-clamp-1">
                              {m.position}
                            </div>
                            <div class="text-[9px] text-slate-400 font-mono mt-0.5 flex items-center gap-1.5">
                              <span>Kelas {m.class}</span>
                              {m.generations?.graduation_year && (
                                <>
                                  <span class="opacity-40">&middot;</span>
                                  <span class="text-cream-600 font-bold">{m.generations.graduation_year}</span>
                                </>
                              )}
                            </div>
                          </div>
                        </div>
                      ))}
                    </div>
                  </div>
                );
              })}
            </div>
          </details>
        </div>
      )}
    </div>
  </section>


  <!-- PAPAN TRANSPARANSI ASPIRASI -->
  <section id="transparansi" class="py-16 sm:py-24 px-4 sm:px-6 bg-cream-100 border-t border-cream-300/40 relative overflow-hidden">
    <!-- Cozy Ambient Glow Orbs -->
    <div class="absolute -top-32 -right-32 w-80 h-80 bg-cream-300/45 rounded-full filter blur-3xl opacity-60 pointer-events-none z-0"></div>
    <div class="absolute -bottom-32 -left-32 w-80 h-80 bg-gold-500/10 rounded-full filter blur-3xl opacity-50 pointer-events-none z-0"></div>

    <div class="max-w-6xl mx-auto space-y-12 relative z-10">
      <div class="text-center max-w-xl mx-auto reveal">
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-cream-200 border border-cream-400/40 text-[9px] font-bold text-slate-500 uppercase tracking-wider font-pixel">
          <img src="/images/mc/map.png" class="w-4 h-4 pixelated shrink-0" alt="Map" />
          Transparansi Kerja
        </span>
        <h2 class="text-2xl sm:text-3xl font-black text-charcoal-900 uppercase tracking-wider mt-2">Papan Aspirasi Siswa</h2>
        <p class="text-slate-500 text-xs mt-2 font-light">Keluhan, masukan, dan laporan tindak lanjut secara terbuka dan aman.</p>
        <div class="w-10 h-1 bg-cream-500 mx-auto mt-3 rounded-full"></div>
      </div>

      {recentAspirations.length === 0 ? (
        <div class="max-w-md mx-auto py-12 text-center bg-white/70 backdrop-blur-sm border border-cream-300/60 rounded-2xl p-8 shadow-sm reveal">
          <span class="text-4xl select-none block mb-3">📭</span>
          <h4 class="text-sm font-bold text-slate-800 uppercase tracking-wide">Papan Aspirasi Masih Bersih</h4>
          <p class="text-slate-500 text-xs mt-2 leading-relaxed font-light">Belum ada keluhan atau aspirasi resmi yang dikirimkan siswa. Jadilah yang pertama menyuarakan masukan Anda!</p>
        </div>
      ) : (
        <div class="marquee-container flex flex-col gap-6 relative z-10 py-2">
          {/* Row 1: Left scrolling track */}
          <div class="marquee-track-left">
            {[...recentAspirations, ...recentAspirations, ...recentAspirations].map((asp, i) => {
              const styles = getStatusStyles(asp.status);

              const date = new Date(asp.created_at).toLocaleDateString('id-ID', {
                day: '2-digit',
                month: 'short'
              });

              const cleanName = anonymizeName(asp.name, asp.class);
              const swayClass = `bubble-sway-${(i % 3) + 1}`;

              return (
                <div 
                  class={`w-[290px] sm:w-[330px] shrink-0 bg-white/90 backdrop-blur-sm border border-cream-300/70 p-5 rounded-2xl shadow-md flex flex-col justify-between space-y-4 hover:scale-[1.03] hover:shadow-lg hover:border-cream-500/50 transition-all duration-300 ${swayClass}`}
                >
                  <div class="space-y-3 text-left">
                    <div class="flex items-center justify-between">
                      <span class={`px-2.5 py-0.5 border text-[9px] font-mono font-bold rounded-full tracking-wider uppercase flex items-center gap-1 ${styles.bg}`}>
                        <span>{styles.emoji}</span> {asp.status}
                      </span>
                      <span class="text-[9px] text-slate-400 font-mono">{date}</span>
                    </div>
                    <p class="text-xs text-slate-700 font-light leading-relaxed italic break-words whitespace-normal">
                      "{asp.content}"
                    </p>
                    
                    {asp.response && (
                      <div class="mt-2 bg-[#FAF6F0] border border-dashed border-cream-400/80 rounded-xl p-2.5 text-left">
                        <span class="text-[8.5px] font-mono font-bold text-cream-700 uppercase tracking-widest block mb-1">💬 Tanggapan Resmi MPK:</span>
                        <p class="text-[10px] text-slate-600 font-serif leading-relaxed italic pr-1 whitespace-pre-wrap">"{asp.response}"</p>
                      </div>
                    )}
                  </div>

                  <div class="flex items-center justify-between pt-3 border-t border-cream-200/50 text-left">
                    <div class="min-w-0">
                      <div class="text-[11px] font-bold text-charcoal-900 truncate">{cleanName}</div>
                      <div class="text-[9px] text-slate-400 font-mono tracking-wider">Kelas: {asp.class}</div>
                    </div>
                    <span class="text-sm select-none">🎈</span>
                  </div>
                </div>
              );
            })}
          </div>

          {/* Row 2: Right scrolling track (Only shown when there are enough items) */}
          {recentAspirations.length > 1 && (
            <div class="marquee-track-right">
              {[...recentAspirations, ...recentAspirations, ...recentAspirations].reverse().map((asp, i) => {
                const styles = getStatusStyles(asp.status);

                const date = new Date(asp.created_at).toLocaleDateString('id-ID', {
                  day: '2-digit',
                  month: 'short'
                });

                const cleanName = anonymizeName(asp.name, asp.class);
                const swayClass = `bubble-sway-${(i % 3) + 1}`;

                return (
                  <div 
                    class={`w-[290px] sm:w-[330px] shrink-0 bg-white/90 backdrop-blur-sm border border-cream-300/70 p-5 rounded-2xl shadow-md flex flex-col justify-between space-y-4 hover:scale-[1.03] hover:shadow-lg hover:border-cream-500/50 transition-all duration-300 ${swayClass}`}
                  >
                    <div class="space-y-3 text-left">
                      <div class="flex items-center justify-between">
                        <span class={`px-2.5 py-0.5 border text-[9px] font-mono font-bold rounded-full tracking-wider uppercase flex items-center gap-1 ${styles.bg}`}>
                          <span>{styles.emoji}</span> {asp.status}
                        </span>
                        <span class="text-[9px] text-slate-400 font-mono">{date}</span>
                      </div>
                      <p class="text-xs text-slate-700 font-light leading-relaxed italic break-words whitespace-normal">
                        "{asp.content}"
                      </p>
                      
                      {asp.response && (
                        <div class="mt-2 bg-[#FAF6F0] border border-dashed border-cream-400/80 rounded-xl p-2.5 text-left">
                          <span class="text-[8.5px] font-mono font-bold text-cream-700 uppercase tracking-widest block mb-1">💬 Tanggapan Resmi MPK:</span>
                          <p class="text-[10px] text-slate-600 font-serif leading-relaxed italic pr-1 whitespace-pre-wrap">"{asp.response}"</p>
                        </div>
                      )}
                    </div>

                    <div class="flex items-center justify-between pt-3 border-t border-cream-200/50 text-left">
                      <div class="min-w-0">
                        <div class="text-[11px] font-bold text-charcoal-900 truncate">{cleanName}</div>
                        <div class="text-[9px] text-slate-400 font-mono tracking-wider">Kelas: {asp.class}</div>
                      </div>
                      <span class="text-sm select-none">🎈</span>
                    </div>
                  </div>
                );
              })}
            </div>
          )}
        </div>
      )}
    </div>
  </section>

  <!-- ASPIRASI SECURE HYDRATED FORM -->
  <section id="aspirasi" class="py-16 sm:py-24 px-4 sm:px-6 bg-cream-200/40 border-t border-cream-300/40 relative overflow-hidden reveal">
    <!-- Cozy Ambient Glow Orbs -->
    <div class="absolute -top-32 -left-32 w-80 h-80 bg-cream-300/35 rounded-full filter blur-3xl opacity-60 pointer-events-none z-0"></div>
    <div class="absolute -bottom-32 -right-32 w-80 h-80 bg-gold-500/10 rounded-full filter blur-3xl opacity-50 pointer-events-none z-0"></div>

    <div class="max-w-3xl mx-auto text-center space-y-4 mb-12 relative z-10">
      <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-cream-200 border border-cream-400/40 text-[9px] font-bold text-slate-500 uppercase tracking-wider font-pixel">
        📢 Suara Siswa
      </span>
      <h2 class="text-2xl sm:text-3xl font-black text-charcoal-900 uppercase tracking-wider flex items-center justify-center gap-2">
        <img src="/images/mc/bell.png" class="w-6 h-6 pixelated inline-block" alt="Bell" />
        Kotak Aspirasi
      </h2>
      <p class="text-slate-600 text-xs sm:text-sm max-w-lg mx-auto font-light leading-relaxed">
        Punya keluhan fasilitas rusak, kritik kebijakan OSIS, atau ide program baru? Suarakan di sini secara aman. Identitas Anda terlindungi dan bisa dikirim secara anonim.
      </p>
      <div class="w-10 h-1 bg-cream-500 mx-auto mt-3 rounded-full"></div>
    </div>
    
    <div class="w-full max-w-xl mx-auto relative z-10">
      <ReactAspirasiForm client:load />
    </div>
  </section>

  <script>
    // Expand viewport smooth realignment for Informasi Tambahan details card
    const infoDetails = document.querySelector('details');
    infoDetails?.addEventListener('toggle', () => {
      if (infoDetails.open) {
        setTimeout(() => {
          infoDetails.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }, 80); // brief delay to allow CSS height expansion
      }
    });

    // Expand viewport smooth realignment for Hall of Prestige details card
    const hallDetails = document.getElementById('hall-of-prestige') as HTMLDetailsElement | null;
    hallDetails?.addEventListener('toggle', () => {
      if (hallDetails.open) {
        setTimeout(() => {
          hallDetails.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }, 80);
      }
    });
  </script>
</Layout>
