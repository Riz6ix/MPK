---
import Layout from '../layouts/Layout.astro';
import ReactAspirasiForm from '../components/ReactAspirasiForm.tsx';
import { supabase } from '../lib/supabase';

export const prerender = false; // Enable live SSR to sync instantly with Supabase CMS on every page hit

// Set lightweight Edge caching headers to optimize CDN delivery
Astro.response.headers.set(
  'Cache-Control', 
  'public, max-age=0, s-maxage=45, stale-while-revalidate=300'
);

// Fetch positions to get active sort hierarchy
let positions: any[] = [];
try {
  const { data, error } = await supabase
    .from('positions')
    .select('*')
    .order('order_index', { ascending: true });
  if (!error && data) {
    positions = data;
  }
} catch (err) {
  console.error("Gagal mengambil data jabatan:", err);
}

// Fetch members from Supabase
let members: any[] = [];
try {
  const { data, error } = await supabase
    .from('members')
    .select('*');
  
  if (!error && data) {
    members = data;
  }
} catch (err) {
  console.error("Gagal mengambil data pengurus:", err);
}

// Fallback seeding in memory if database is empty so the site looks stunning on first load
if (members.length === 0) {
  members = [
    { id: '1', name: 'Tri Dewi Utami', position: 'Ketua MPK', class: 'XII-F1', commission: 'Inti', avatar_url: null, order_index: 0, gender: 'Perempuan' },
    { id: '2', name: 'Muhamad Saripudin', position: 'Wakil Ketua', class: 'XII-F5', commission: 'Inti', avatar_url: null, order_index: 1, gender: 'Laki-laki' },
    { id: '3', name: 'Siti Nurasyiah', position: 'Sekretaris I', class: 'XI-F1', commission: 'Inti', avatar_url: null, order_index: 2, gender: 'Perempuan' },
    { id: '4', name: 'Erissa Valencia Putri', position: 'Sekretaris II', class: 'XI-F7', commission: 'Inti', avatar_url: null, order_index: 3, gender: 'Perempuan' },
    { id: '5', name: 'Tiara Dewi Anjani', position: 'Bendahara', class: 'XII-F9', commission: 'Inti', avatar_url: null, order_index: 4, gender: 'Perempuan' },
    { id: '6', name: 'Rizky Setiawan', position: 'Developer', class: 'XII-F5', commission: 'Inti', avatar_url: null, order_index: 5, gender: 'Laki-laki' },
    { id: '7', name: 'Lesti', position: 'Koordinator Komisi A', class: 'XI-F1', commission: 'A', avatar_url: null, order_index: 0, gender: 'Perempuan' },
    { id: '8', name: 'Charissa Aini', position: 'Anggota Komisi A', class: 'XI-F5', commission: 'A', avatar_url: null, order_index: 1, gender: 'Perempuan' },
    { id: '9', name: 'Muhamad Saep', position: 'Koordinator Komisi B', class: 'XII-F3', commission: 'B', avatar_url: null, order_index: 0, gender: 'Laki-laki' },
    { id: '10', name: 'Muhamad Rizky Nur Giffari', position: 'Koordinator Komisi C', class: 'XII-F8', commission: 'C', avatar_url: null, order_index: 0, gender: 'Laki-laki' },
    { id: '11', name: 'Saparudin', position: 'Koordinator Komisi D', class: 'XII-F1', commission: 'D', avatar_url: null, order_index: 0, gender: 'Laki-laki' },
    { id: '12', name: 'Diva Khalifatul Hasanah', position: 'Koordinator Komisi E', class: 'XI-F1', commission: 'E', avatar_url: null, order_index: 0, gender: 'Perempuan' },
    { id: '13', name: 'Bagus Adi Darmawan', position: 'Koordinator Komisi F', class: 'XII-F7', commission: 'F', avatar_url: null, order_index: 0, gender: 'Laki-laki' }
  ];
}

// Sort members by position's order_index if positions are available, else fallback to standard sorting
if (positions.length > 0) {
  members.sort((a, b) => {
    const posA = positions.find(p => p.title === a.position);
    const posB = positions.find(p => p.title === b.position);
    
    const indexA = posA ? posA.order_index : 999;
    const indexB = posB ? posB.order_index : 999;
    
    return indexA - indexB;
  });
} else {
  members.sort((a, b) => a.order_index - b.order_index);
}

// Fetch recent aspirations from Supabase
let recentAspirations: any[] = [];
try {
  const { data, error } = await supabase
    .from('aspirations')
    .select('name, class, content, status, response, created_at')
    .order('created_at', { ascending: false })
    .limit(12);
  
  if (!error && data) {
    recentAspirations = data;
  }
} catch (err) {
  console.error("Gagal mengambil data aspirasi:", err);
}

const getStatusStyles = (status: string) => {
  switch (status) {
    case 'Selesai':
      return {
        bg: 'bg-emerald-50 border-emerald-300/70 text-emerald-800',
        emoji: '🌲'
      };
    case 'Sedang Ditinjau':
      return {
        bg: 'bg-amber-50 border-amber-300/70 text-amber-800',
        emoji: '🔍'
      };
    case 'Anomali':
      return {
        bg: 'bg-purple-50 border-purple-300/70 text-purple-800',
        emoji: '🪐'
      };
    case 'Pending Anggaran':
      return {
        bg: 'bg-yellow-50 border-yellow-300/70 text-yellow-800',
        emoji: '💸'
      };
    case 'Birokrasi':
      return {
        bg: 'bg-orange-50 border-orange-300/70 text-orange-800',
        emoji: '📝'
      };
    default:
      return {
        bg: 'bg-slate-50 border-slate-300 text-slate-700',
        emoji: '📭'
      };
  }
};

// Seed fallbacks if database has none (empty for live DB sync)
if (recentAspirations.length === 0) {
  recentAspirations = [];
}

const anonymizeName = (name: string, className: string) => {
  const lower = name.toLowerCase();
  if (lower === 'anonim' || lower.includes('siswa')) {
    return name;
  }
  return `Siswa Kelas ${className}`;
};

// Grouping (Filter only Active Members for main organogram)
const activeMembers = members.filter(m => m.status === 'Aktif' || !m.status);
const coreMembers = activeMembers.filter(m => m.commission === 'Inti');
const commissionA = activeMembers.filter(m => m.commission === 'A');
const commissionB = activeMembers.filter(m => m.commission === 'B');
const commissionC = activeMembers.filter(m => m.commission === 'C');
const commissionD = activeMembers.filter(m => m.commission === 'D');
const commissionE = activeMembers.filter(m => m.commission === 'E');
const commissionF = activeMembers.filter(m => m.commission === 'F');

const commissions = [
  { id: 'A', title: 'Komisi A', desc: 'Mengawasi kerja OSIS seksi bidang 1 sampai 4. Menyusun aturan dasar organisasi (AD/ART).', list: commissionA },
  { id: 'B', title: 'Komisi B', desc: 'Mengawasi kerja OSIS seksi bidang 5 sampai 7. Menyusun AD/ART organisasi.', list: commissionB },
  { id: 'C', title: 'Komisi C', desc: 'Mengawasi seluruh program kerja OSIS dan menjadi tim evaluasi kinerja umum.', list: commissionC },
  { id: 'D', title: 'Komisi D', desc: 'Berperan sebagai tim penampung dan penyalur aspirasi warga sekolah.', list: commissionD },
  { id: 'E', title: 'Komisi E', desc: 'Mengelola media digital publikasi dan penyebaran informasi kegiatan sekolah.', list: commissionE },
  { id: 'F', title: 'Komisi F', desc: 'Melakukan pengawasan internal dan evaluasi objektif program kerja MPK.', list: commissionF }
];

// Fetch Alumni (Purna Bakti) from dedicated alumni table with generation join
let alumniMembers: any[] = [];
try {
  const { data: alumniData, error: alumniError } = await supabase
    .from('alumni')
    .select('*, generations(name, active_year, graduation_year)')
    .order('name', { ascending: true });
  if (!alumniError && alumniData) {
    alumniMembers = alumniData;
  }
} catch (err) {
  console.error('Gagal mengambil data alumni:', err);
}

// Group alumni by generation name
const demisionerByGen: Record<string, any[]> = {};
alumniMembers.forEach(m => {
  const gen = m.generations?.name || 'Angkatan I';
  if (!demisionerByGen[gen]) demisionerByGen[gen] = [];
  demisionerByGen[gen].push(m);
});

// Sort generations descending (newest first)
const sortedGenerations = Object.keys(demisionerByGen).sort((a, b) => b.localeCompare(a, undefined, { numeric: true, sensitivity: 'base' }));
---

<Layout>
  <!-- HERO SECTION -->
  <section id="hero" class="relative min-h-[88vh] flex items-center justify-center py-16 sm:py-24 px-4 sm:px-6 overflow-hidden bg-gradient-to-b from-cream-100 to-cream-200">
    <!-- Soft warm circular glows (animate drift) -->
    <div class="absolute top-10 left-10 w-80 h-80 bg-cream-500/8 rounded-full blur-3xl animate-drift" style="animation-duration:9s"></div>
    <div class="absolute bottom-10 right-10 w-96 h-96 bg-cream-300/30 rounded-full blur-3xl animate-drift" style="animation-duration:12s;animation-delay:-4s"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-gold-100/20 rounded-full blur-3xl animate-drift" style="animation-duration:15s;animation-delay:-2s"></div>

    <div class="max-w-4xl mx-auto text-center space-y-8 z-10">
      <div class="animate-fade-up" style="animation-delay:0.1s">
        <span class="inline-flex items-center gap-1.5 px-4 py-1.5 rounded-full bg-cream-200 border border-cream-400/50 text-[9px] font-bold text-slate-600 uppercase tracking-wider mb-6 font-pixel">
          <img src="/images/mc/oak_leaves.png" class="w-4 h-4 pixelated shrink-0" alt="Leaves" />
          Majelis Perwakilan Kelas
        </span>
        <h1 class="text-4xl sm:text-6xl font-black tracking-tight text-charcoal-900 leading-tight uppercase">
          Suara Anda,<br/>
          <span class="bg-gradient-to-r from-cream-500 via-yellow-700 to-amber-800 bg-clip-text text-transparent">Masa Depan Kita</span>
        </h1>
      </div>
      
      <p class="text-sm sm:text-base text-slate-600 max-w-2xl mx-auto leading-relaxed font-light animate-fade-up" style="animation-delay:0.3s">
        Majelis Perwakilan Kelas SMAN 1 Malingping hadir sebagai pengawal aspirasi siswa, pengawas objektif kinerja OSIS, dan katalisator demokrasi demi menciptakan ekosistem sekolah yang harmonis, transparan, dan inklusif.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 pt-4 animate-fade-up" style="animation-delay:0.5s">
        <a href="#aspirasi" class="w-full sm:w-auto px-8 py-4 rounded-full text-white font-bold text-sm shadow-lg cursor-pointer btn-shimmer">
          🌱 Sampaikan Aspirasi Sekarang
        </a>
        <a href="#about" class="w-full sm:w-auto px-8 py-4 rounded-full bg-white border border-cream-400 text-slate-700 font-bold text-sm hover:bg-cream-200 hover:text-slate-900 transition duration-200 shadow-sm cursor-pointer">
          Pelajari Peran Kami ↓
        </a>
      </div>
    </div>

    <!-- Decorative bottom fade -->
    <div class="absolute bottom-0 left-0 w-full h-24 bg-gradient-to-t from-cream-100 to-transparent pointer-events-none"></div>
  </section>

  <!-- ABOUT / VISI MISI -->
  <section id="about" class="py-16 sm:py-24 px-4 sm:px-6 bg-cream-100 border-t border-cream-300/40 relative overflow-hidden">
    <!-- Cozy Ambient Glow Orbs -->
    <div class="absolute -top-32 -left-32 w-80 h-80 bg-cream-300/35 rounded-full filter blur-3xl opacity-60 pointer-events-none z-0"></div>
    <div class="absolute -bottom-32 -right-32 w-80 h-80 bg-gold-500/10 rounded-full filter blur-3xl opacity-50 pointer-events-none z-0"></div>

    <div class="max-w-6xl mx-auto space-y-16 relative z-10">
      <div class="text-center max-w-xl mx-auto reveal">
        <h2 class="text-2xl sm:text-3xl font-black text-charcoal-900 uppercase tracking-wider">Tentang Kami</h2>
        <div class="w-10 h-1 bg-cream-500 mx-auto mt-3 rounded-full"></div>
      </div>
 
      <!-- Cozy Inner Wrapper: Groups Visi-Misi and More Info closely and consistently -->
      <div class="space-y-4">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
          <!-- Visi Card -->
          <div class="bg-white/80 backdrop-blur-sm border border-cream-300/60 p-8 rounded-2xl shadow-sm space-y-4 card-lift reveal group" style="transition-delay: 0ms">
            <div class="flex items-center space-x-4">
              <div class="p-2.5 bg-cream-200 rounded-xl shrink-0 transition-transform duration-300 group-hover:scale-110 group-hover:rotate-6">
                <img 
                  src="/images/mc/compass.png" 
                  class="w-8 h-8 pixelated group-hover:animate-float-cozy block" 
                  alt="Visi"
                />
              </div>
              <h3 class="text-lg font-bold text-charcoal-900 uppercase tracking-wide">Visi</h3>
            </div>
            <p class="text-sm text-slate-600 leading-relaxed font-light">
              Mewujudkan MPK SMAN 1 Malingping sebagai organisasi yang visioner, adaptif, dan profesional dalam menjalankan peran strategisnya sebagai pengawal aspirasi siswa, pengawas OSIS, serta sebagai mitra kolaboratif yang aktif membangun budaya sekolah yang demokratis, partisipatif, dan berintegritas.
            </p>
          </div>
 
        <!-- Misi Card -->
        <div class="bg-white/80 backdrop-blur-sm border border-cream-300/60 p-8 rounded-2xl shadow-sm space-y-4 card-lift reveal group" style="transition-delay: 150ms">
          <div class="flex items-center space-x-4">
            <div class="p-2.5 bg-cream-200 rounded-xl shrink-0 transition-transform duration-300 group-hover:scale-110 group-hover:-rotate-6">
              <img 
                src="/images/mc/writable_book.png" 
                class="w-8 h-8 pixelated group-hover:animate-float-cozy block" 
                alt="Misi"
              />
            </div>
            <h3 class="text-lg font-bold text-charcoal-900 uppercase tracking-wide">Misi</h3>
          </div>
          <ul class="space-y-3.5 text-xs sm:text-sm text-slate-600 font-light">
            <li class="flex items-start space-x-3">
              <i class="ph-duotone ph-check-circle text-cream-500 text-lg shrink-0 mt-0.5"></i>
              <span>Membangun sinergi yang solid dan komunikatif antara MPK, OSIS, serta pihak sekolah dalam menciptakan lingkungan organisasi yang harmonis.</span>
            </li>
            <li class="flex items-start space-x-3">
              <i class="ph-duotone ph-check-circle text-cream-500 text-lg shrink-0 mt-0.5"></i>
              <span>Mengawasi pelaksanaan program kerja OSIS secara aktif dan objektif agar tetap selaras dengan rencana dan tujuan bersama.</span>
            </li>
            <li class="flex items-start space-x-3">
              <i class="ph-duotone ph-check-circle text-cream-500 text-lg shrink-0 mt-0.5"></i>
              <span>Mengoptimalkan peran MPK sebagai lembaga legislatif siswa yang bertanggung jawab, aspiratif, serta representatif.</span>
            </li>
            <li class="flex items-start space-x-3">
              <i class="ph-duotone ph-check-circle text-cream-500 text-lg shrink-0 mt-0.5"></i>
              <span>Mendorong penguatan karakter anggota MPK melalui pengembangan profesionalisme, integritas, dan etika organisasi.</span>
            </li>
          </ul>
        </div>
      </div>

      <!-- Landasan Hukum & Informasi Tambahan Accordion (More Info) -->
      <div class="reveal">
        <details class="group bg-white/80 hover:bg-white/90 backdrop-blur-sm border border-cream-300/60 open:border-cream-500/50 rounded-2xl shadow-sm open:shadow-md transition-all duration-300 [&_summary::-webkit-details-marker]:hidden">
          <summary class="flex items-center justify-between p-6 cursor-pointer select-none hover:text-cream-500 transition-colors duration-300">
            <div class="flex items-center gap-3">
              <img src="/images/mc/trialomen.png" class="w-6 h-6 pixelated shrink-0" alt="Omen" />
              <span class="text-xs sm:text-sm font-black text-charcoal-900 uppercase tracking-wide group-open:text-cream-600">Informasi Tambahan, Landasan Hukum, & Kode Etik MPK</span>
            </div>
            <span class="transition-transform duration-300 group-open:rotate-180 text-cream-500 text-lg shrink-0">
              <i class="ph-bold ph-caret-down"></i>
            </span>
          </summary>
          <div class="px-6 pb-6 border-t border-cream-200/60 pt-6 space-y-8 text-slate-600 font-light text-xs sm:text-sm animate-fade-up" style="animation-duration: 0.5s">
            
            <!-- Grid 1: Landasan Hukum vs Tiga Fungsi Legislatif -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 leading-relaxed">
              <div class="space-y-4">
                <h4 class="text-xs font-black uppercase tracking-wider text-charcoal-900 font-mono flex items-center gap-1.5 border-b border-cream-200 pb-2">
                  <i class="ph-duotone ph-book-bookmark text-amber-500 text-sm"></i> Landasan Hukum Konstitusional Kesiswaan
                </h4>
                <p>
                  Eksistensi Majelis Perwakilan Kelas (MPK) dan OSIS di bawah tata kelola sekolah menengah dijamin oleh payung hukum formal kenegaraan Republik Indonesia:
                </p>
                <ul class="space-y-3.5 list-none">
                  <li class="flex items-start gap-2">
                    <span class="text-cream-500 shrink-0 font-bold font-mono">01.</span>
                    <span><strong>Permendiknas No. 39 Tahun 2008 (Pasal 4)</strong>: Menegaskan bahwa pembinaan kesiswaan diselenggarakan melalui organisasi kesiswaan. Di mana OSIS merupakan wadah resmi internal sekolah, dan MPK bertindak sebagai lembaga perwakilan legislatif kelas (parlemen siswa) yang mengawasi kinerja OSIS serta menampung aspirasi murid secara independen.</span>
                  </li>
                  <li class="flex items-start gap-2">
                    <span class="text-cream-500 shrink-0 font-bold font-mono">02.</span>
                    <span><strong>Undang-Undang No. 20 Tahun 2003 tentang Sisdiknas (Pasal 3)</strong>: Menjamin hak seluruh peserta didik untuk mengembangkan diri secara demokratis, mandiri, kreatif, toleran, dan bertanggung jawab melalui wadah organisasi kepemimpinan kepengurusan siswa.</span>
                  </li>
                  <li class="flex items-start gap-2">
                    <span class="text-cream-500 shrink-0 font-bold font-mono">03.</span>
                    <span><strong>Keputusan Dirjen Dikdasmen No. 226/C/Kep/0/1992</strong>: Mengatur petunjuk pelaksanaan pembinaan kesiswaan secara sistemik, menjadi fondasi utama penyusunan Aturan Dasar dan Aturan Rumah Tangga (AD/ART) organisasi kesiswaan di tingkat satuan pendidikan.</span>
                  </li>
                </ul>
              </div>
              
              <div class="space-y-4">
                <h4 class="text-xs font-black uppercase tracking-wider text-charcoal-900 font-mono flex items-center gap-1.5 border-b border-cream-200 pb-2">
                  <i class="ph-duotone ph-scales text-cream-500 text-sm"></i> Tiga Pilar Fungsi Utama Legislatif Siswa (MPK)
                </h4>
                <p>
                  Mengadopsi prinsip ketatanegaraan yang demokratis dan transparan, MPK SMAN 1 Malingping memegang 3 fungsi utama demi mewujudkan tata kelola organisasi siswa yang kredibel:
                </p>
                <ul class="space-y-4 list-none">
                  <li class="flex items-start gap-3 group/pilar">
                    <span class="p-2 bg-amber-50 text-amber-600 rounded-xl text-xs shrink-0 select-none flex items-center justify-center border border-amber-100 group-hover/pilar:bg-amber-100 transition-colors duration-200"><i class="ph-duotone ph-file-text text-base"></i></span>
                    <div>
                      <strong>Fungsi Legislasi (Aturan & AD/ART)</strong>: Merumuskan, merevisi, menyelaraskan, dan menetapkan konstitusi Aturan Dasar and Aturan Rumah Tangga (AD/ART) serta Anggaran Dasar OSIS/MPK SMAN 1 Malingping agar relevan dengan kebutuhan murid.
                    </div>
                  </li>
                  <li class="flex items-start gap-3 group/pilar">
                    <span class="p-2 bg-emerald-50 text-emerald-600 rounded-xl text-xs shrink-0 select-none flex items-center justify-center border border-emerald-100 group-hover/pilar:bg-emerald-100 transition-colors duration-200"><i class="ph-duotone ph-eye text-base"></i></span>
                    <div>
                      <strong>Fungsi Pengawasan (Oversight Kinerja)</strong>: Mengevaluasi jalannya program kerja pengurus OSIS secara objektif dan berkala, menyelenggarakan Sidang Pleno Tengah Semester, serta Sidang Laporan Pertanggungjawaban (LPJ) Akhir Masa Jabatan.
                    </div>
                  </li>
                  <li class="flex items-start gap-3 group/pilar">
                    <span class="p-2 bg-indigo-50 text-indigo-600 rounded-xl text-xs shrink-0 select-none flex items-center justify-center border border-indigo-100 group-hover/pilar:bg-indigo-100 transition-colors duration-200"><i class="ph-duotone ph-megaphone text-base"></i></span>
                    <div>
                      <strong>Fungsi Advokasi (Penyaluran Suara)</strong>: Menyerap, menampung, menyaring, merumuskan, dan menyalurkan aspirasi, kritik, dan rekomendasi perubahan dari para siswa secara langsung ke jajaran pimpinan sekolah (Wakasek Kesiswaan & Kepala Sekolah).
                    </div>
                  </li>
                </ul>
              </div>
            </div>

            <!-- Grid 2: Hak Demokrasi Siswa SMANSAMAL & SOP Kerja (Inisiatif Proaktif) -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 leading-relaxed pt-6 border-t border-cream-200/50">
              <div class="space-y-4">
                <h4 class="text-xs font-black uppercase tracking-wider text-charcoal-900 font-mono flex items-center gap-1.5 border-b border-cream-200 pb-2">
                  <i class="ph-duotone ph-shield-checkered text-emerald-600 text-sm"></i> Piagam Hak Konstitusi Demokrasi Murid SMANSAMAL
                </h4>
                <p>
                  Demi terciptanya ekosistem sekolah yang transparan dan aman bagi setiap murid, MPK menjamin hak kedaulatan aspirasi siswa melalui piagam komitmen berikut:
                </p>
                <ul class="space-y-3.5 list-none">
                  <li class="flex items-start gap-2">
                    <span class="text-emerald-600 shrink-0 font-bold font-mono flex items-center mt-1"><i class="ph-bold ph-check text-xs"></i></span>
                    <span><strong>Hak Kebebasan Bersuara</strong>: Setiap murid SMAN 1 Malingping tanpa terkecuali berhak menyampaikan kritik konstruktif, keluhan kegagalan fasilitas, atau ide program kerja tanpa rasa takut akan intimidasi atau tekanan akademis.</span>
                  </li>
                  <li class="flex items-start gap-2">
                    <span class="text-emerald-600 shrink-0 font-bold font-mono flex items-center mt-1"><i class="ph-bold ph-check text-xs"></i></span>
                    <span><strong>Hak Proteksi Anonimitas Mutlak</strong>: Kami mengadopsi enkripsi satu arah berbasis Salt-Hash IP. Identitas asli murid yang memilih opsi anonim terlindungi secara matematis dari pelacakan eksternal.</span>
                  </li>
                  <li class="flex items-start gap-2">
                    <span class="text-emerald-600 shrink-0 font-bold font-mono flex items-center mt-1"><i class="ph-bold ph-check text-xs"></i></span>
                    <span><strong>Hak Akuntabilitas Advokasi</strong>: Murid berhak memantau, mendesak, dan menerima status perkembangan aspirasi yang telah mereka serahkan sampai selesai diproses di CMS MPK.</span>
                  </li>
